# Copy this file to .env and fill in your real key.
# Supported values: gemini, openai
LLM_PROVIDER=gemini

# Gemini is used by CrewAI through CrewAI's Gemini LLM integration.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash

# Recommended for Gemini. Use "openai" only if you specifically want Gemini's OpenAI-compatible endpoint.

# OpenAI alternative.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.2

# Optional output settings.
ARTICLE_TOPIC=Production-Ready AI Agent Architecture in 2026

# CrewAI generation tuning.
CREWAI_TEMPERATURE=0.35
CREWAI_MAX_TOKENS=8192


